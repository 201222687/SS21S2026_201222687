                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    c.cliente_id,
    p.producto_sku,
    f.cantidad_vendida,
    f.total_venta
FROM fact_ventas f
JOIN dim_cliente c ON f.cliente_key = c.cliente_key
JOIN dim_producto p ON f.producto_key = p.producto_key</property>
