FROM fact_ventas f
JOIN dim_cliente c ON f.cliente_key = c.cliente_key
JOIN dim_producto p ON f.producto_key = p.producto_key) [refTable]
where [refTable].[cliente_id] = ? and [refTable].[producto_sku] = ?</property>
