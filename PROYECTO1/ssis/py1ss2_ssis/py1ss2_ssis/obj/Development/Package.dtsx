                <property
                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    FechaTransaccion,
    ClienteId,
    ProductoSKU,
    Departamento,
    Municipio,
    CanalVenta,
    CantidadVendida,
    PrecioUnitario,
    CostoUnitario,
    DescuentoAplicado,
    (CantidadVendida * PrecioUnitario - DescuentoAplicado) AS total_venta,
    ExistenciaAntesVenta,
    ExistenciaDespuesVenta
FROM dbo.TransaccionesVenta;</property>
